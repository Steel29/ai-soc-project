# === AI Model Configuration ===
# Where the AI model API lives.
# Dev (from WSL2/Docker): host.docker.internal resolves to the Windows host where Ollama is running.
# Staging: use your laptop's LAN IP, e.g. http://192.168.1.50:11434/v1
# Production: vLLM on GPU server, e.g. http://gpu-server-ip:8000/v1
VLLM_BASE_URL=http://host.docker.internal:11434/v1
# The model name as served. Ollama: "gemma4" (default). vLLM: "phi-4-triage"
# Fallback if gemma4 is slow alongside Docker: "llama3.1:8b" (4.9GB, faster)
MODEL_NAME=gemma4

# Ollama base URL (without /v1) — used by embedding worker and any service using Ollama directly
# Same host as VLLM_BASE_URL but without the /v1 path
OLLAMA_BASE_URL=http://host.docker.internal:11434
# Embedding model — must be available in Ollama (nomic-embed-text is already pulled)
EMBEDDING_MODEL=nomic-embed-text

# === Infrastructure ===
REDPANDA_BROKERS=redpanda:9092
OPENSEARCH_HOST=http://opensearch:9200
QDRANT_HOST=http://qdrant:6333

# === Credentials — CHANGE BEFORE USE ===
MINIO_ROOT_USER=socai
MINIO_ROOT_PASSWORD=changeme_minio_2026
POSTGRES_USER=socai
POSTGRES_PASSWORD=changeme_pg_2026
POSTGRES_DB=socai

# === SIEM ===
SIEM_VENDOR=LogRhythm
SIEM_INGEST_PORT=5140

# === Application ===
FEEDBACK_UI_PORT=8888
